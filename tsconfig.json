{
  "extends": "@rubiin/tsconfig/tsconfig.node.json",
  "compilerOptions": {
    "types": ["node", "jest", "express", "multer"], // @types are no longer auto-discovered (see §1.6)
    "rootDir": "./src", // no longer inferred from source files (see §1.5)
    "outDir": "./dist",
    "paths": {
      "@lib/*": ["./src/lib/*"],
      "@common/*": ["./src/common/*"],
      "@modules/*": ["./src/modules/*"],
      "@entities": ["./src/entities"],
      "@mocks": ["./src/_mocks_"],
      "@generated": ["./src/generated"]
    },
    "declaration": true
  },
  "include": ["src/**/*"],
  "typeRoots": ["./src/common/@types/typings"]
}
